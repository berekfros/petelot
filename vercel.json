{
  "rewrites": [
    { "source": "/landing", "destination": "/www/landing/index.html" },
    { "source": "/catalog", "destination": "/www/catalog/index.html" },
    { "source": "/portofolio", "destination": "/www/portofolio/index.html" },
    { "source": "/dashboard", "destination": "/Dashboard/dashboard/index.html" },
    { "source": "/auth", "destination": "/Dashboard/auth/index.html" },
    { "source": "/(.*)", "destination": "/www/$1" }
  ]
}
